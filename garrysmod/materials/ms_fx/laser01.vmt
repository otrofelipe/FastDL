
"UnlitGeneric"
{
             "$basetexture" "ms_fx/laser01"
               $alphatest 0
              $addself 1
                "$translucent" "1"
	"$vertexcolor" "1"
	"$vertexalpha" "1"
 "Proxies"
 {
  "AnimatedTexture"
  {
   "animatedTextureVar" "$basetexture"
   "animatedTextureFrameNumVar" "$frame"
   "animatedTextureFrameRate" "20"
  }
}