"Sprite"
{

"$basetexture" "ms_fx/laser_eye"
               $additive 1
                "$translucent" "1"
                "$spriteorientation" "vp_parallel"
               "$spriteorigin" "[ 0.50 0.50 ]"
	"$vertexcolor" "1"
	"$vertexalpha" "1"
               "$nocull" "1"
 "Proxies"
 {
  "AnimatedTexture"
  {
   "animatedTextureVar" "$basetexture"
   "animatedTextureFrameNumVar" "$frame"
   "animatedTextureFrameRate" "20"
  }

}
